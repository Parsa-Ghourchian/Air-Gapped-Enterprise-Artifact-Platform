# Project
COMPOSE_PROJECT_NAME=airgap_artifacts

# Nexus
NEXUS_IMAGE=sonatype/nexus3:3.93.2
NEXUS_ADMIN_PASSWORD=change-me

# Traefik
TRAEFIK_IMAGE=traefik:v3.6.22

# Monitoring
PROMETHEUS_IMAGE=prom/prometheus:v3.13.0
GRAFANA_IMAGE=grafana/grafana:13.0.3
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.11.1
CADVISOR_IMAGE=ghcr.io/google/cadvisor:0.56.2

# Grafana Login
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Local URLs
NEXUS_URL=http://localhost:8081
NEXUS_DOCKER_HOSTED=localhost:5000
NEXUS_DOCKER_PROXY=localhost:5001
NEXUS_DOCKER_GROUP=localhost:5002

# Landing Page
LANDING_IMAGE=nginx:1.27-alpine

# Reports
REPORTS_DIR=reports

# Nexus Raw Repositories
NEXUS_RAW_BACKUPS=raw-backups
NEXUS_RAW_OFFLINE_BUNDLES=raw-offline-bundles
NEXUS_RAW_RELEASES=raw-releases

# Lightweight policy
ENABLE_APT_MINI_REPO=true
HOST_PROJECT_ROOT=/absolute/path/to/airgapped-enterprise-artifact-platform
PORTAL_IMAGE=airgap-deployment-portal:0.4.0
PORTAL_ADMIN_USER=admin
PORTAL_ADMIN_PASSWORD=change-me
PORTAL_ADMIN_PASSWORD_HASH=
PORTAL_SESSION_SECRET=change-me-random-hex
PORTAL_STRICT_HOST_KEY=false
PORTAL_REMOTE_DEFAULT_DIR=/tmp/airgap-deployments
PORTAL_ENABLE_GRYPE_SCAN=false
PORTAL_BLOCK_CRITICAL=true
PORTAL_BLOCK_LATEST_TAG=true
PORTAL_MIN_FREE_DISK_MB=2048
PORTAL_CLEANUP_KEEP_DAYS=14
